import numpy as np
import matplotlib.pyplot as plt

class sine_Wave:
    def __init__(self,phase, frequency, stoptime_input, starttime_input):
        self.phase=phase
        self.frequency=frequency
        self.stoptime_input=stoptime_input
        self.starttime_input=starttime_input
    
    def time(self):
       return np.arange(self.starttime_input,self.stoptime_input,0.1)
    
    def sine_wave(self):
        return np.sin(self.frequency*self.time() + np.radians(self.phase))
    


s1=sine_Wave(90,10, 20, 2)
s1.sine_wave()


plt.plot(s1.time(),s1.sine_wave(),color='purple')
plt.title("Sine Wave s1 using classes")
plt.xlabel("Time")
plt.ylabel("Data points")
plt.show()
print(f" The values of the sine wave data points are {s1.sine_wave()}")


class new_sine_wave(sine_Wave):
    def __init__(self, phase, frequency, amplitude,stoptime_input, starttime_input):
        super().__init__(phase,frequency,starttime_input,stoptime_input)
        self.amplitude=amplitude

    def amp_sine_wave(self):
        return self.amplitude*self.sine_wave()

s2=new_sine_wave(90,10,2,3,15)
s2.amp_sine_wave()

plt.plot(s2.time(),s2.amp_sine_wave(),color='red')
plt.title("Sine Wave s2 using classes with added amplitude")
plt.xlabel("Time")
plt.ylabel("Data points")
plt.show()

